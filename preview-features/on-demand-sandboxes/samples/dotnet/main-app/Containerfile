# Builds the orchestrator (main-app) image deployed to Azure Container Apps.
#
# Built amd64-only: azd builds this remotely via ACR Tasks (azure.yaml docker.remoteBuild),
# whose classic builder runs on amd64 and does not support BuildKit syntax (no `# syntax`
# directive, no `--platform=$TARGETPLATFORM`/`ARG TARGETARCH`). Container Apps also runs
# amd64, so the runtime identifier is pinned to linux-x64. Building amd64 also sidesteps
# the Grpc.Tools linux_arm64 protoc segfault seen under arm64 emulation on Apple Silicon.

FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build

WORKDIR /src/dts-ondemand-sandbox-codegen-demo
COPY . .

WORKDIR /src/dts-ondemand-sandbox-codegen-demo/main-app
RUN dotnet publish main-app.csproj \
        -c Release \
        -r linux-x64 \
        --self-contained false \
        -o /app/publish \
        /p:DebugSymbols=false \
        /p:DebugType=None \
    && find /app/publish -type f \( -name '*.xml' -o -name '*.pdb' \) -delete

FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS runtime
WORKDIR /app

COPY --from=build /app/publish ./
# Ship the sample dataset and point the app at it.
COPY data ./data
ENV DEMO_CSV_PATH=/app/data/sales_q1.csv

ENTRYPOINT ["dotnet", "CodegenMainApp.dll"]
