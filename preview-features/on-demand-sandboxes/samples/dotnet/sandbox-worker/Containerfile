# Builds the on-demand sandbox worker image that DTS starts on demand.
#
# Built amd64-only: built remotely via ACR Tasks (scripts/acr-build.sh runs
# `az acr build --platform linux/amd64`), whose classic builder runs on amd64 and does not
# support BuildKit syntax (no `# syntax` directive, no `--platform=$TARGETPLATFORM`/
# `ARG TARGETARCH`). DTS sandboxes run amd64, so the runtime identifier is pinned to
# linux-x64. Building amd64 also sidesteps the Grpc.Tools linux_arm64 protoc segfault seen
# under arm64 emulation on Apple Silicon.
#
# The sandbox worker is a .NET app that shells out to python3, so we install pandas in the
# runtime stage.

FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build

WORKDIR /src/dts-ondemand-sandbox-codegen-demo
COPY . .

WORKDIR /src/dts-ondemand-sandbox-codegen-demo/sandbox-worker
RUN dotnet publish sandbox-worker.csproj \
        -c Release \
        -r linux-x64 \
        --self-contained false \
        -o /app/publish \
        /p:DebugSymbols=false \
        /p:DebugType=None \
    && find /app/publish -type f \( -name '*.xml' -o -name '*.pdb' \) -delete

FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS runtime
WORKDIR /app

# Install python3 + pandas. These are the only tools the LLM-generated scripts can use.
RUN apt-get update \
    && apt-get install -y --no-install-recommends python3 python3-pip \
    && pip3 install --no-cache-dir --break-system-packages pandas==2.2.* \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

ENV ASPNETCORE_URLS=http://+:8080
EXPOSE 8080

COPY --from=build /app/publish ./

ENTRYPOINT ["dotnet", "CodegenSandboxWorker.dll"]
